rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Pools
    match /pools/{poolId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      // Bets: users can only write their own bets, all authenticated users can read
      match /bets/{betId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == request.resource.data.userId;
        allow delete: if request.auth != null
          && (request.auth.uid == resource.data.userId
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy);
      }

      // Leaderboard: readable by all, writable by self or pool admin
      match /leaderboard/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == uid
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy);
      }
    }

    // Legacy groups (read-only for migration)
    match /groups/{groupCode} {
      allow read: if request.auth != null;
      match /{sub}/{docId} {
        allow read: if request.auth != null;
      }
    }
  }
}
