rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'UKfTa82FSHaj72HsyjB4oGzL9Rg1';
    }

    // Users: self read/write, admin can read/delete all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Pools
    match /pools/{poolId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.members || isAdmin());
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.createdBy || isAdmin());

      // Bets
      match /bets/{betId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null
          && request.auth.uid == request.resource.data.userId;
        allow delete: if request.auth != null
          && (request.auth.uid == resource.data.userId
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy
              || isAdmin());
      }

      // Special bets (one doc per user, all tournament-wide picks).
      // Anti-cheat: you can only read OTHER players' picks once the deadline has
      // passed (opening match kickoff, 2026-06-11 16:00 UTC = 1781193600000 ms).
      // Your own picks, the admin and the pool creator can always read.
      match /specialBets/{uid} {
        allow read: if request.auth != null
          && (request.auth.uid == uid
              || request.time.toMillis() >= 1781193600000
              || isAdmin()
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy);
        // Owner creates/edits their own picks.
        allow create: if request.auth != null
          && request.auth.uid == uid
          && request.auth.uid == request.resource.data.userId;
        // Owner edits picks; admin / pool creator write awarded points on resolve.
        allow update: if request.auth != null
          && (request.auth.uid == uid
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy
              || isAdmin());
        allow delete: if request.auth != null
          && (request.auth.uid == uid
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy
              || isAdmin());
      }

      // Leaderboard
      match /leaderboard/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null
          && (request.auth.uid == uid
              || request.auth.uid == get(/databases/$(database)/documents/pools/$(poolId)).data.createdBy
              || isAdmin());
      }
    }

    // Admin logs: only admin can read/write
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
    }

    // Match results: admin writes, all read
    match /matchResults/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Special-bet correct answers (tournament-wide): admin writes, all read
    match /specialResults/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Analytics
    match /analytics/{docId} {
      allow read: if isAdmin();
      allow create, update: if request.auth != null;
    }

    // Legacy groups (read-only for migration)
    match /groups/{groupCode} {
      allow read: if request.auth != null;
      match /{sub}/{docId} {
        allow read: if request.auth != null;
      }
    }
  }
}
